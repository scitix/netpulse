    type: ResultType
    retval: Optional[list[DriverExecutionResult]] = None
    error: Optional[Any] = None
    model_config = ConfigDict(
        json_schema_extra={
            "example": {
                "type": 1,
                "retval": [
                    {
                        "command": "show version",
                        "stdout": "Arista vEOS\nHardware version: 4.25.4M",
                        "stderr": "",
                        "exit_status": 0,
                        "download_url": None,
                        "metadata": {
