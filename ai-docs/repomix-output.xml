            "health": "GET /health - Health check",
        },
        "webhook_url": f"http://{config.server_host}:{config.server_port}/webhook",
        "total_messages": message_counter,
        "configuration": {
            "max_messages": config.max_messages,
            "retention_hours": config.retention_hours,
