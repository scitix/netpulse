        except Exception as e:
            log.error(f"Error in sending command: {e}")
            return [
                DriverExecutionResult(
                    command=" ".join(command),
                    stdout="",
                    stderr=str(e),
                    exit_status=1,
                    metadata=self._get_base_metadata(start_time),
